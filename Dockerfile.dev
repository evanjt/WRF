# Development Dockerfile for fast WRF rebuilding
# Inherits from the main wrf-snpack image and only rebuilds WRF with modified files

FROM wrf-snpack AS dev-build
LABEL description="Fast WRF development rebuild environment"
ENV BASE_DIR=/home/wrfuser/wrf-build \
    NETCDF=${BASE_DIR}/libs/netcdf \
    JASPERLIB=${BASE_DIR}/libs/grib2/lib \
    JASPERINC=${BASE_DIR}/libs/grib2/include \
    LD_LIBRARY_PATH="${BASE_DIR}/libs/lib:${BASE_DIR}/libs/netcdf/lib:${BASE_DIR}/libs/grib2/lib:${BASE_DIR}/WRF/phys/cryowrf/snowpack/lib:${BASE_DIR}/WRF/phys/cryowrf/meteoio/lib" \
    PATH=".:/home/wrfuser/.local/bin:${BASE_DIR}/libs/netcdf/bin:${BASE_DIR}/libs/bin:${PATH}"

USER root
RUN apt-get update && apt-get install -y gdb nano

USER wrfuser
WORKDIR ${BASE_DIR}

# Copy only the modified phys directory for fast rebuild
COPY --chown=wrfuser:wrfuser phys/ ${BASE_DIR}/WRF/phys/
COPY --chown=wrfuser:wrfuser main/ ${BASE_DIR}/WRF/main/
COPY --chown=wrfuser:wrfuser Registry/ ${BASE_DIR}/WRF/Registry/


WORKDIR ${BASE_DIR}/WRF
RUN ./compile em_real -j 20 && \
    if [ -f "main/wrf.exe" ]; then \
        echo "WRF compilation successful: wrf.exe found at main/wrf.exe"; \
        ls -la main/wrf.exe; \
    else \
        echo "WRF compilation failed: wrf.exe not found"; \
        echo "Looking for executable in alternative locations..."; \
        find . -name "wrf.exe" -type f 2>/dev/null || echo "No wrf.exe found anywhere"; \
        exit 1; \
    fi

# Set working directory for development
WORKDIR ${BASE_DIR}/WRF/test/em_real

ENTRYPOINT ["/bin/bash"]
